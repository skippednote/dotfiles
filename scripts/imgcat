#!/usr/bin/env bash
# Display an image in terminals supporting the Kitty graphics protocol
# (Ghostty, Kitty, WezTerm, iTerm2 via kitty protocol)
#
# Usage: imgcat <path>

set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: imgcat <path>" >&2
  exit 1
fi

input="$1"
tmp_file=""

cleanup() {
  [ -n "$tmp_file" ] && rm -f "$tmp_file"
}
trap cleanup EXIT

if [[ "$input" =~ ^https?:// ]]; then
  tmp_file=$(mktemp /tmp/imgcat.XXXXXX)
  curl -sfL -o "$tmp_file" "$input" || { echo "Error: failed to download: $input" >&2; exit 1; }
  file="$tmp_file"
else
  file="$input"
  if [ ! -f "$file" ]; then
    echo "Error: file not found: $file" >&2
    exit 1
  fi
fi

mime=$(file --brief --mime-type "$file")
case "$mime" in
  image/png|image/jpeg|image/gif|image/webp|image/bmp) ;;
  *)
    echo "Error: unsupported type: $mime" >&2
    exit 1
    ;;
esac

data=$(base64 < "$file")
chunk_size=4096
len=${#data}
offset=0

while [ "$offset" -lt "$len" ]; do
  chunk="${data:$offset:$chunk_size}"
  remaining=$(( len - offset - chunk_size ))

  if [ "$offset" -eq 0 ] && [ "$remaining" -le 0 ]; then
    # Single chunk — send all at once
    printf '\e_Gf=100,a=T;%s\e\\' "$chunk"
  elif [ "$offset" -eq 0 ]; then
    # First chunk of many
    printf '\e_Gf=100,a=T,m=1;%s\e\\' "$chunk"
  elif [ "$remaining" -le 0 ]; then
    # Last chunk
    printf '\e_Gm=0;%s\e\\' "$chunk"
  else
    # Middle chunk
    printf '\e_Gm=1;%s\e\\' "$chunk"
  fi

  offset=$(( offset + chunk_size ))
done

echo
